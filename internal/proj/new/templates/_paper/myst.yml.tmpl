# See docs at: https://mystmd.org/guide/frontmatter
#
# Article title + subtitle live in main.md's frontmatter (single source of
# truth). Everything below is shared metadata for every export.
version: 1
project:
  short_title: "{{.ProjectName}}"
{{- if .Description}}
  description: "{{.Description}}"
{{- end}}
  keywords: []
  license: CC-BY-4.0
  bibliography:
    - refs.bib
  authors:
    - name: {{.AuthorName}}
{{- if .AuthorEmail}}
      email: {{.AuthorEmail}}
{{- end}}
      affiliations: []
  affiliations: []
{{- if eq .Kind "python"}}
  # Notebook output cleanup — strip matplotlib repr strings (`<Figure size
  # 640x480 with 1 Axes>`) and stderr from rendered cells.
  settings:
    output_matplotlib_strings: remove
    output_stderr: remove-error
  exclude:
    - _build/**
    - "**/.jupyter_cache/**"
{{- end}}
{{- if eq .MdLayout "composed"}}
  # Document "parts" are template slots (abstract, keypoints, etc.) — the
  # template decides where each lands on the page. The body is whatever is
  # listed in `toc:` below.
  parts:
    abstract: sections/abstract.md
    keypoints: sections/keypoints.md
    acknowledgements: sections/acknowledgements.md
    data_availability: sections/opendata.md
{{- end}}
  toc:
    - file: main.md
  exports:
    - format: typst
{{- if eq .Template "lab"}}
      template: ./_templates/paper
{{- else if ne .Template "default"}}
      template: {{.Template}}
{{- end}}
      output: pdfs/main.pdf
      # Submission knobs — flip as needed:
      # line_numbers: true          # on by default
      # line_number_scope: document # or "page" to restart per page
      # anonymize: true             # double-blind: hide authors/affiliations
      # title_page: true            # push abstract + body to page 2
      # abstract_page: true         # abstract on page 2, body on page 3

site:
  template: book-theme
  title: "{{.ProjectName}}"
  options:
    hide_toc: false
    hide_search: false
    hide_outline: false
