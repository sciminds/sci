[1.3, "o", "\r\n  \u001b[1;36mEmergent Abilities of Large Language Models\u001b[m\r\n"]
[1.4, "o", "  \u001b[90mABC12345\u001b[m  \u001b[90mpreprint\u001b[m\r\n\r\n"]
[1.6, "o", "  \u001b[90mauthors:\u001b[m Jason Wei, Yi Tay, Rishi Bommasani, Colin Raffel\r\n"]
[1.7, "o", "  \u001b[90mdate:\u001b[m 2022-06-15\r\n"]
[1.8, "o", "  \u001b[90mpublication:\u001b[m arXiv preprint\r\n"]
[1.9, "o", "  \u001b[90mdoi:\u001b[m 10.48550/arXiv.2206.07682\r\n"]
[2.0, "o", "  \u001b[90murl:\u001b[m https://arxiv.org/abs/2206.07682\r\n\r\n"]
[2.2, "o", "  \u001b[90mabstract:\u001b[m\r\n"]
[2.3, "o", "  Scaling up language models has been shown to predictably improve\r\n"]
[2.4, "o", "  performance across a wide range of tasks. We discuss an unpredictable\r\n"]
[2.5, "o", "  phenomenon we refer to as emergent abilities of large language models.\r\n\r\n"]
[2.7, "o", "  \u001b[90mtags:\u001b[m llm, scaling, emergence\r\n"]
